{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "A real estate property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "string" },
        "beds": { "type": "number" },
        "baths": { "type": "number" },
        "bathrooms": { "type": "number" },
        "garages": { "type": "number" },
        "hasBBQ": { "type": "boolean" },
        "hasPool": { "type": "boolean" },
        "hasLaundry": { "type": "boolean" },
        "area": { "type": "string" },
        "image": { "type": "string" },
        "gallery": { "type": "array" },
        "tag": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["title", "location", "price", "beds", "baths", "image", "type"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global website settings and images",
      "type": "object",
      "properties": {
        "watermarkImage": { "type": "string" },
        "heroImage": { "type": "string" },
        "aboutImage": { "type": "string" },
        "ctaImage": { "type": "string" },
        "footerLogo": { "type": "string" },
        "profileImage": { "type": "string" }
      }
    },
    "AdminRole": {
      "title": "Admin Role",
      "description": "Admin access definition",
      "type": "object",
      "properties": {
        "isAdmin": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Real estate properties for sale or rent"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global application settings (e.g., images)"
    },
    "/admins/{userId}": {
      "schema": "AdminRole",
      "description": "Admin users"
    }
  }
}
