rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'location', 'price', 'type']) &&
             data.title is string && data.title.size() <= 200 &&
             data.location is string && data.location.size() <= 200 &&
             data.price is string && data.price.size() <= 100 &&
             data.type in ['sale', 'rental'] &&
             (!('beds' in data) || data.beds is number) &&
             (!('baths' in data) || data.baths is number) &&
             (!('bathrooms' in data) || data.bathrooms is number) &&
             (!('garages' in data) || data.garages is number) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1048576)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 5000)) &&
             (!('area' in data) || (data.area is string && data.area.size() <= 100)) &&
             (!('tag' in data) || (data.tag is string && data.tag.size() <= 100)) &&
             (!('hasBBQ' in data) || data.hasBBQ is bool) &&
             (!('hasPool' in data) || data.hasPool is bool) &&
             (!('hasLaundry' in data) || data.hasLaundry is bool) &&
             (!('gallery' in data) || (data.gallery is list && data.gallery.size() <= 20));
    }
    
    match /properties/{propertyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(propertyId) && isValidProperty(incoming());
      allow update: if isAdmin() && isValidProperty(incoming());
      allow delete: if isAdmin();
    }
    
    function isValidSettings(data) {
      return (!('watermarkImage' in data) || (data.watermarkImage is string && data.watermarkImage.size() <= 1048576)) &&
             (!('heroImage' in data) || (data.heroImage is string && data.heroImage.size() <= 1048576)) &&
             (!('aboutImage' in data) || (data.aboutImage is string && data.aboutImage.size() <= 1048576)) &&
             (!('ctaImage' in data) || (data.ctaImage is string && data.ctaImage.size() <= 1048576)) &&
             (!('footerLogo' in data) || (data.footerLogo is string && data.footerLogo.size() <= 1048576)) &&
             (!('profileImage' in data) || (data.profileImage is string && data.profileImage.size() <= 1048576));
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
      allow update: if isAdmin() && isValidSettings(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId && 
                       (request.auth.token.email == "frcalvescaldovino@gmail.com") && 
                       incoming().keys().hasOnly(['isAdmin']) && 
                       incoming().isAdmin == true;
    }
  }
}
